---
import Layout from "../layouts/Layout.astro";
// Definimos el stack tecnológico una sola vez
const techStack = [
    { type: "devicon", icon: "devicon-python-plain colored" },
    { type: "devicon", icon: "devicon-googlecloud-plain colored" },
    { type: "img", src: "/icons/uipath.svg", alt: "UiPath" },
    { type: "img", src: "/icons/appian.svg", alt: "Appian", css: "icon-wide" },
    { type: "img", src: "/icons/blueprism.svg", alt: "Blue Prism", css: "icon-extra-wide" },
    { type: "img", src: "https://cdn.simpleicons.org/n8n/FF6666", alt: "n8n" },
    { type: "img", src: "/icons/pa.svg", alt: "Power Automate" },
    { type: "devicon", icon: "devicon-docker-plain colored" },
    { type: "devicon", icon: "devicon-playwright-plain colored" },
    { type: "devicon", icon: "devicon-azuresqldatabase-plain colored" },
    { type: "devicon", icon: "devicon-azure-plain colored" },
    { type: "img", src: "https://cdn.simpleicons.org/github/181717", alt: "github" },
    { type: "devicon", icon: "devicon-git-plain colored" },
    { type: "devicon", icon: "devicon-dot-net-plain colored" }
];

// Definimos los repositorios en un arreglo
const repositorios = [
    {
        titulo: "RaaS Automation: Previred",
        url: "https://github.com/cpalacios-dev/raas-previred-automation-core",
        descripcion: "API REST (Flask/Waitress) para extracción y centralización de indicadores previsionales. Implementa arquitectura RaaS v2.0, integrando <strong>Playwright</strong> y <strong>BS4</strong> para scraping, <strong>Pandas</strong> para ETL, almacenamiento en GCS y alertas vía SendGrid.",
        tags: ["Flask", "Playwright", "Pandas", "GCP Storage", "SendGrid", "Pydantic"]
    },
    {
        titulo: "IDP Smart Extractor (GenAI)",
        url: "https://github.com/cpalacios-dev/idp-smart-extractor-service",
        descripcion: "Servicio de procesamiento inteligente de documentos (IDP). Utiliza el modelo <strong>Gemini 3 Flash</strong> para transformar archivos PDF caóticos en datos estructurados JSON listos para sistemas ERP.",
        tags: ["Gemini 3 Flash", "Flask", "PyPDF", "Pydantic"]
    },
    {
        titulo: "Economic Data Scraper",
        url: "https://github.com/cpalacios-dev/economic-data-ingestion-scraper",
        descripcion: "Microservicio serverless diseñado para extracción, limpieza y estructuración de datos económicos chilenos. Preparado bajo principios POO para despliegue en GCP Cloud Run o AWS Lambda.",
        tags: ["Python", "Requests", "Logging", "JSON"]
    }
	
];


---

<Layout title="Cristian Palacios | Portfolio Engineer & RPA Developer">
	<main>
		<section id="hero" class="hero-section">
			<div class="hero-image-container">
                <img src="/perfil.png" alt="Cristian Palacios" class="hero-profile-photo" />
            </div>
            
            <div class="hero-text-content">
                <h1>Cristian Palacios</h1>
                <p class="role">
                    Ingeniero de Portafolios TI | Desarrollador RPA, Cloud & GenAI
                </p>
                <div class="status-badge">
                    <span class="dot"></span> Disponible para nuevos desafíos
                </div>
                <div class="social-links">
                    <a
                        href="https://www.linkedin.com/in/cpalacios-borquez/"
                        target="_blank"
                        title="LinkedIn"
                    >
                        <i class="devicon-linkedin-plain"></i>
                    </a>
                    <a
                        href="https://github.com/cpalacios-dev"
                        target="_blank"
                        title="GitHub"
                    >
                        <i class="devicon-github-original"></i>
                    </a>
                    <a
                        href="mailto:cpalacios.borquez@gmail.com"
                        title="Enviar Email"
                    >
                        <i class="devicon-google-plain"></i>
                    </a>
                </div>
	        </div>
			<div class="description">
                Ingeniero Informático con un perfil híbrido que combina la ejecución técnica avanzada con la visión estratégica de la <strong>Gestión de Portafolios (VDD)</strong>. 
                Traduzco requerimientos operativos complejos en soluciones de software de alto impacto bajo el modelo <strong>Robot as a Service (RaaS)</strong>. 
                Mi enfoque va más allá de la automatización tradicional: desarrollo <strong>microservicios y APIs (Python/Flask)</strong>, diseño <strong>arquitecturas escalables (GCP, Serverless)</strong> e integro <strong>IA Generativa (GenAI)</strong> para llevar la eficiencia operativa y el retorno de inversión al siguiente nivel.
            </div>
			
			<div class="tech-ticker">
                <div class="ticker-content">
                    {/* Unimos el arreglo consigo mismo [...techStack, ...techStack] para duplicarlo automáticamente */}
                    {[...techStack, ...techStack].map((tech) => (
                        tech.type === "devicon" ? (
                            <i class={tech.icon}></i>
                        ) : (
                            <img src={tech.src} class={`local-icon ${tech.css || ""}`} alt={tech.alt} />
                        )
                    ))}
                </div>
            </div>

		</section>

	    <section id="expertise">
            <h2>Core Expertise y Stack</h2>
            <div class="expertise-grid">
                <div class="skill-item">
                    <i class="devicon-googlecloud-plain colored"></i>
                    <span><strong>Cloud & Arquitectura:</strong> GCP (Cloud Run, Secret Manager), Microservicios (RaaS), Integración de APIs (REST/SOAP).</span>
                </div>
                <div class="skill-item">
                    <i class="devicon-python-plain colored"></i>
                    <span><strong>Automatización & IA:</strong> Python, Playwright, Appian, n8n, UiPath, Power Automate. Procesamiento inteligente de documentos (OCR/NLP).</span>
                </div>
                <div class="skill-item">
                    <i class="devicon-jira-plain colored"></i>
                    <span><strong>Gestión, DevOps & Agilidad:</strong> CI/CD, Git (GitHub/GitLab), Ciclo de vida del software (SDLC), Scrum y PMBOK.</span>
                </div>
            </div>
        </section>

		<section id="raas-architecture">
			<div class="raas-container">
				<div class="raas-badge">Core Expertise</div>
				<h2>Arquitectura RaaS (Robot as a Service)</h2>
				<p>
					Diseño de microservicios transaccionales bajo modelo <strong
						>RaaS</strong
					>, utilizando
					<strong>Python</strong> y <strong>Playwright</strong>.
					Desplegados sobre infraestructura serverless en <strong
						>Google Cloud Platform (GCP - Cloud Run)</strong
					> para garantizar alta disponibilidad y escalabilidad masiva.
				</p>
			</div>
		</section>

		<section id="proyectos">
            <h2>Experiencia de Alto Impacto</h2>
            <div class="project-grid">
                <article class="project-card">
                    <header>
                        <span class="company">SURA AFP CAPITAL</span>
                        <h3>Modelo Robot as a Service (RaaS)</h3>
                    </header>
                    <p>
                        Desarrollo de microservicios transaccionales en <strong>Cloud Run</strong> e integración de <strong>IA (OCR/NLP)</strong> para la gestión automatizada de nóminas críticas, reduciendo drásticamente la carga operativa manual.
                    </p>
                    <div class="tags">
                        <span>GCP</span><span>Python</span><span>Playwright</span><span>OCR/NLP</span>
                    </div>
                </article>

                <article class="project-card">
                    <header>
                        <span class="company">CLARO CHILE S.A.</span>
                        <h3>Modernización e Integración API</h3>
                    </header>
                    <p>
                        Liderazgo técnico en la integración de sistemas legacy del sector telecomunicaciones mediante <strong>APIs REST/SOAP</strong>, asegurando la escalabilidad y mejorando la interoperabilidad corporativa.
                    </p>
                    <div class="tags">
                        <span>APIs</span><span>Arquitectura</span><span>SDLC</span>
                    </div>
                </article>
            </div>
        </section>

		<section id="vdd-strategy">
			<h2>Estrategia VDD (Value Driven Delivery)</h2>
			<p style="color: #a3a3a3; margin-bottom: 1.5rem;">
				No automatizo a ciegas. Aseguro la alineación con los objetivos del negocio mediante la gestión de stakeholders y la priorización de backlogs utilizando modelos matemáticos de eficiencia:
			</p>
			<div class="vdd-table-container">
				<table>
					<thead>
						<tr>
							<th>Modelo</th>
							<th>Aplicación</th>
							<th>Meta</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td><strong>WSJF</strong></td>
							<td>Costo del retraso</td>
							<td>Agilidad Financiera</td>
						</tr>
						<tr>
							<td><strong>RICE / ICE</strong></td>
							<td>Impacto vs Esfuerzo</td>
							<td>ROI de Automatización</td>
						</tr>
						<tr>
							<td><strong>MoSCoW</strong></td>
							<td>Clasificación Crítica</td>
							<td>Cumplimiento de Plazos</td>
						</tr>
					</tbody>
				</table>
			</div>
		</section>

		<section id="certificaciones">
			<h2>Certificaciones y Especialización</h2>
			<div class="cert-grid">
				<div class="cert-card gold">
					<div class="cert-header">
						<img src="/icons/blueprism.svg" class="local-icon-bp" alt="Blue Prism" />
						<span>Oficial</span>
					</div>
					<h4>Blue Prism Certified Developer</h4>
					<p>SS&C Blue Prism | 2020</p>
				</div>

				<div class="cert-card academy">
					<div class="cert-header">
						<img src="/icons/appian.svg" class="local-icon-appian" alt="Appian" />
						<span>Academy 2026</span>
					</div>
					<h4>Appian Developer</h4>
					<p>Appian Academy | Low-Code Automation</p>
				</div>

				<div class="cert-card academy">
					<div class="cert-header">
						<img src="/icons/uipath.svg" class="" alt="uipath" />
						<span>Academy</span>
					</div>
					<h4>RPA Developer Foundation</h4>
					<p>UiPath Academy | EY Consulting</p>
				</div>

				<div class="cert-card tech">
					<div class="cert-header">
						<i class="devicon-python-plain colored"></i>
						<span>Curso</span>
					</div>
					<h4>Análisis de Datos con Python</h4>
					<p>Desafío Latam | Oct 2025</p>
					
				</div>

				<div class="cert-card tech">
					<div class="cert-header">
						<i class="devicon-redhat-plain colored"></i>
						<span>Especialización</span>
					</div>
					<h4>Red Hat OpenShift Training</h4>
					<p>Red Hat | Contenedores y Kubernetes</p>
				</div>

				<div class="cert-card tech">
					<div class="cert-header">
						<img src="/icons/pa.svg" class="" alt="Power Automate" />
						<span>Formación</span>
					</div>
					<h4>Power Automate Desktop / Cloud</h4>
					<p>Udemy | Curso Completo RPA</p>
				</div>
			</div>
		</section>
		<section id="trayectoria">
            <h2>Trayectoria y Formación</h2>
            <div class="timeline">
                
                <div class="timeline-item">
                    <div class="timeline-content">
                        <span class="year">2025 - 2026</span>
                        <h4>Ingeniero de Portafolios TI & Desarrollador RPA</h4>
                        <span class="company">SURA AFP Capital (Kibernum)</span>
                        <p>
                            Desarrollo de arquitectura RaaS y microservicios transaccionales. Orquestación de procesos críticos utilizando <strong>Python, Playwright</strong> y plataformas automatizadas (UiPath, Appian), logrando eficiencia operativa a gran escala.
                        </p>
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-content">
                        <span class="year">2023 - 2025</span>
                        <h4>Líder de Proyectos de Integración & RPA</h4>
                        <span class="company">Claro Chile / Consultoría (EY)</span>
                        <p>
                            Liderazgo en la modernización tecnológica e integración de sistemas legacy mediante APIs REST/SOAP. Automatización de procesos core para telecomunicaciones y el <strong>sector bancario (Scotiabank, Itaú, Santander)</strong>.
                        </p>
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-content">
                        <span class="year">2024</span>
                        <h4>Posgrado en Gestión de Portafolios</h4>
                        <span class="company">Tecnológico de Monterrey</span>
                        <p>
                            Especialización estratégica en <strong>Value Driven Delivery (VDD)</strong>, marcos ágiles (Scrum) y PMBOK. Enfoque en vincular la ejecución tecnológica con los objetivos y el ROI del negocio.
                        </p>
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-content">
                        <span class="year">2020</span>
                        <h4>Ingeniería en Informática</h4>
                        <span class="company">IPCHILE</span>
                        <p>
                            Titulación profesional con enfoque en desarrollo de software, despliegue de bases de datos y fundamentos sólidos de arquitectura de sistemas.
                        </p>
                    </div>
                </div>

            </div>
        </section>

		<section id="github-repos">
    <h2>Arquitecturas de Referencia (GitHub)</h2>
    <p style="color: #a3a3a3; margin-bottom: 2rem; line-height: 1.6;">
        Por estrictos acuerdos de confidencialidad (NDA) con el sector bancario y telco,
        mi código de producción corporativo es privado. 
        Estos repositorios públicos sirven como demostración técnica de mis estándares de arquitectura, 
        POO y despliegue continuo.
    </p>
    
    <div class="repo-grid">
        {repositorios.map((repo) => (
            <a href={repo.url} target="_blank" class="repo-card">
                <div class="repo-header">
                    <i class="fa-brands fa-github"></i>
                    <h3>{repo.titulo}</h3>
                </div>
                <p set:html={repo.descripcion}></p>
                <div class="tags">
                    {repo.tags.map((tag) => (
                        <span>{tag}</span>
                    ))}
                </div>
            </a>
        ))}
    </div>
</section>

		<section id="contacto" class="contact-section">
            <div class="contact-content">
                <h2>¿Listo para optimizar tus procesos?</h2>
                <p>
                    Actualmente estoy abierto a nuevos desafíos. Ya sea que busques modernizar la arquitectura de tu empresa o escalar operaciones con RPA, mi bandeja de entrada está abierta.
                </p>
                <div class="cta-container">
                    <a
                        href="https://www.linkedin.com/in/cpalacios-borquez/"
                        target="_blank"
                        class="btn btn-linkedin"
                        title="Conectar en LinkedIn"
                    >
                        <i class="fa-brands fa-linkedin"></i> LinkedIn
                    </a>
                    
                    <a 
                        href="https://wa.me/56942056649?text=Hola%20Cristian,%20vi%20tu%20portafolio%20y%20me%20gustaría%20contactarte." 
                        target="_blank"
                        class="btn btn-whatsapp"
                        title="Escribir por WhatsApp"
                    >
                        <i class="fa-brands fa-whatsapp"></i> WhatsApp
                    </a>

                    <a 
                        href="mailto:cpalacios.borquez@gmail.com" 
                        class="btn btn-mail"
                        title="Enviar Email"
                    >
                        <i class="fa-solid fa-envelope"></i> Email
                    </a>
                    
                    <a 
                        href="/cv_cpalacios.pdf" 
                        download 
                        class="btn btn-cv"
                        title="Descargar Currículum"
                    >
                        <i class="fa-solid fa-file-pdf"></i> CV
                    </a>
                </div>
            </div>
        </section>
	</main>
</Layout>
<style>
	/* 1. Configuración de Contenedor Principal */
	main {
		margin: auto;
		padding: 2rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: #ffffff;
		line-height: 1.6;
		font-family: "Inter", sans-serif;
		overflow-x: hidden;
	}

	/* --- SECCIÓN HERO ACTUALIZADA CON FOTO --- */
    .hero-section {
        display: flex;
        flex-wrap: wrap; /* Para móviles */
        align-items: center; /* Centrado vertical */
        justify-content: center; /* Centrado horizontal */
        gap: 3rem; /* Espacio entre foto y texto */
        margin-top: 4rem;
        margin-bottom: 2rem;
        text-align: left; /* Alineación de texto por defecto */
    }

    .hero-image-container {
        flex: 0 0 auto; /* La foto no se estira */
    }

    .hero-profile-photo {
        width: 180px;
        height: 180px;
        border-radius: 50%; /* Foto redonda */
        object-fit: cover; /* Asegura que la foto no se deforme */
        
        /* Diseño del anillo tecnológico */
        background: padding-box, linear-gradient(45deg, #4f39fa, #da62c4) border-box;
        border: 4px solid transparent; /* Ancho del anillo */
        
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4), 0 0 15px rgba(218, 98, 196, 0.2);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hero-profile-photo:hover {
        transform: scale(1.03);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), 0 0 20px rgba(218, 98, 196, 0.3);
    }

    .hero-text-content {
        flex: 1 1 400px; /* El texto ocupa el resto del espacio */
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: flex-start; /* Alinea los links y badge a la izquierda */
    }

    .hero-section h1 {
        font-size: 3rem;
        font-weight: 800;
        margin-top: 0;
        margin-bottom: 0.2rem; /* Menos espacio para el h1 */
        background: linear-gradient(45deg, #4f39fa, #da62c4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hero-text-content .role {
        font-size: 1.4rem;
        color: #a3a3a3;
        margin-top: 0;
        margin-bottom: 0.5rem;
        font-weight: 500;
    }

    .hero-text-content .status-badge,
    .hero-text-content .social-links {
        margin-left: 0; /* Asegura alineación izquierda */
        padding-left: 0;
    }

    .hero-text-content .social-links {
        display: flex;
        gap: 1.2rem; /* Espacio uniforme entre iconos */
        margin-top: 1rem;
        margin-bottom: 0.5rem;
    }

    /* La descripción se mantiene centrada debajo de la foto y texto */
    .hero-section .description {
        width: 100%; /* Ocupa todo el ancho */
        font-size: 1.15rem;
        max-width: 700px; /* Limita ancho para legibilidad */
        margin: 1rem auto 0 auto;
        line-height: 1.6;
        color: #d1d1d1;
    }

    

	/* 2. Tipografía y Títulos */

	section {
		margin-top: 4rem;
	}
	strong {
		color: #da62c4;
	}

	/* 3. Limpieza Global de Enlaces */
	a {
		text-decoration: none !important;
		outline: none;
	}

	/* 4. Estilos de iconos  */
	.tech-ticker {
        width: 100%;
        overflow: hidden;
        background: #1e1e1e;
        padding: 2rem 0;
        margin-top: 2rem;
        border-radius: 12px;
        border: 1px solid #333;
		white-space: nowrap;
    }

    .ticker-content {
        display: flex;
        align-items: center;
        width: max-content;
        animation: scroll 35s linear infinite;
    }

    /* ESTADO INICIAL: Todos en Gris */
    .ticker-content i,
    .ticker-content .local-icon {
        margin: 0 2.5rem;
        flex-shrink: 0;
        height: 2.8rem; /* Altura uniforme para todos */
        width: auto;    /* Que el ancho sea proporcional */
        filter: grayscale(100%) brightness(0.7); /* Gris y un poco apagado */
        transition: all 0.4s ease;
    }

    /* ESTADO HOVER: Recuperan Color Original */
    .ticker-content i:hover,
    .ticker-content .local-icon:hover {
        filter: grayscale(0%) brightness(1); /* Color real y brillo normal */
        transform: scale(1.15);
    }

    /* Ajuste para los iconos de fuente de Devicon */
    .ticker-content i {
        font-size: 2.8rem;
        display: flex;
        align-items: center;
    }

    /* Nivelación para logos muy anchos (Appian y Blue Prism) */
    /* Aunque tengan el mismo alto, les damos un poco más de aire si es necesario */
    .icon-wide {
        height: 2.2rem !important; /* Un poco más bajo para no verse gigante al ser ancho */
    }

    .icon-extra-wide {
        height: 2rem !important; /* Blue prism es texto largo, mejor bajarle un pelo el alto */
    }

    @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

	/* 5. Grids y Tarjetas Generales */
	.expertise-grid {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.project-grid,
	.cert-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 1.5rem;
		margin-top: 2rem;
	}
	.skill-item,
	.project-card,
	.cert-card {
		background: #1e1e1e;
		border: 1px solid #333;
		border-radius: 12px;
		padding: 1.5rem;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease;
	}
	.project-card:hover {
		transform: scale(1.02);
		border-color: #4f39fa;
	}

	/* 6. Certificaciones (Bordes Glow) */
	.cert-card {
		display: flex;
		flex-direction: column;
		transition:
			transform 0.3s ease,
			border-color 0.3s ease,
			box-shadow 0.3s ease;
	}
	.cert-card:hover {
		transform: translateY(-5px);
	}
	.cert-card.gold {
		border: 1px solid #ffd700;
		box-shadow: 0 4px 15px rgba(255, 215, 0, 0.1);
	}
	.cert-card.gold span {
		background: #ffd700;
		color: #000;
		font-weight: bold;
	}
	.cert-card.academy {
		border: 1px solid #4f39fa;
		box-shadow: 0 4px 15px rgba(79, 57, 250, 0.1);
	}
	.cert-card.academy span {
		background: #4f39fa;
		color: #fff;
	}
	.cert-card.tech {
		border: 1px solid #da62c4;
		box-shadow: 0 4px 15px rgba(218, 98, 196, 0.1);
	}
	.cert-card.tech span {
		background: #da62c4;
		color: #fff;
	}

	.cert-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1rem;
	}
	.cert-header i {
		font-size: 1.8rem;
	}
	.cert-header img {
		height: 1.8rem;
		width: 1.8rem;
	}

	.cert-header .local-icon-bp{
		width: 8rem;
	}

	.cert-header .local-icon-appian{
		width: 5rem;
	}

    
	.cert-header span {
		font-size: 0.65rem;
		padding: 2px 8px;
		border-radius: 4px;
		text-transform: uppercase;
	}
	.cert-card .id {
		font-size: 0.7rem;
