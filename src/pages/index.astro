        <section id="github-repos">
            <h2>Arquitecturas de Referencia (GitHub)</h2>
            <p style="color: #a3a3a3; margin-bottom: 2rem; line-height: 1.6;">
                Por estrictos acuerdos de confidencialidad (NDA) con el sector
                bancario y telco, mi código de producción corporativo es
                privado. Estos repositorios públicos sirven como demostración
                técnica de mis estándares de arquitectura, POO y despliegue
                continuo.
            </p>

            <div class="repo-grid">
                {
                    repositorios.map((repo) => (
                        <a href={repo.url} target="_blank" class="repo-card">
                            <div class="repo-header">
                                <i class="fa-brands fa-github" />
                                <h3>{repo.titulo}</h3>
                            </div>
