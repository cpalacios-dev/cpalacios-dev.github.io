---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Cristian Palacios | Portfolio Engineer & RPA Developer">
    <main>
        <section id="hero">
            <h1>Cristian Palacios</h1>
            <p class="role">
                Ingeniero de Portafolios TI | Desarrollador RPA & Cloud
            </p>
            <div class="status-badge">
                <span class="dot"></span> Disponible para nuevos desafíos
            </div>
            <div class="social-links">
                <a href="https://www.linkedin.com/in/cpalacios-borquez/" target="_blank" title="LinkedIn">
                    <i class="devicon-linkedin-plain"></i>
                </a>
                <a href="https://github.com/cpalacios-dev" target="_blank" title="GitHub">
                    <i class="devicon-github-original"></i>
                </a>
                <a href="mailto:cpalacios.borquez@gmail.com" title="Enviar Email">
                    <i class="devicon-google-plain"></i>
                </a>
            </div>

            <div class="description">
                Especialista en modernización tecnológica mediante el diseño de
                <strong>arquitecturas escalables en la nube (GCP)</strong> y la implementación
                de modelos <strong>Robot as a Service (RaaS)</strong>. Lidero la
                convergencia entre la visión estratégica y la solidez técnica.
            </div>

            <div class="tech-ticker">
                <div class="ticker-content">
                    <i class="devicon-python-plain"></i>
                    <i class="devicon-googlecloud-plain"></i>
                    <i class="devicon-uipath-plain"></i>
                    <i class="devicon-docker-plain"></i>
                    <i class="devicon-azuresqldatabase-plain"></i>
                    <i class="devicon-github-original"></i>
                    <i class="devicon-dot-net-plain"></i>
                    <i class="devicon-appian-plain"></i>
                    <i class="devicon-python-plain"></i>
                    <i class="devicon-googlecloud-plain"></i>
                    <i class="devicon-uipath-plain"></i>
                    <i class="devicon-docker-plain"></i>
                    <i class="devicon-azuresqldatabase-plain"></i>
                    <i class="devicon-github-original"></i>
                    <i class="devicon-dot-net-plain"></i>
                    <i class="devicon-appian-plain"></i>
                </div>
            </div>
        </section>

        <section id="expertise">
            <h2>Stack Tecnológico y de Gestión</h2>
            <div class="expertise-grid">
                <div class="skill-item">
                    <i class="devicon-googlecloud-plain colored"></i>
                    <span><strong>Cloud & DevOps:</strong> GCP (Cloud Run), Docker, Arquitectura Serverless.</span>
                </div>
                <div class="skill-item">
                    <i class="devicon-python-plain colored"></i>
                    <span><strong>Backend & Automatización:</strong> Python, Playwright, orquestación con Appian y n8n.</span>
                </div>
                <div class="skill-item">
                    <i class="devicon-jira-plain colored"></i>
                    <span><strong>Gestión Estratégica:</strong> VDD, Priorización WSJF/RICE, Metodologías Ágiles (Scrum).</span>
                </div>
            </div>
        </section>

        <section id="raas-architecture">
            <div class="raas-container">
                <div class="raas-badge">Core Expertise</div>
                <h2>Arquitectura RaaS (Robot as a Service)</h2>
                <p>
                    Diseño de microservicios transaccionales bajo modelo <strong>RaaS</strong>, utilizando
                    <strong>Python</strong> y <strong>Playwright</strong>.
                    Desplegados sobre infraestructura serverless en <strong>GCP (Cloud Run)</strong> para garantizar alta disponibilidad y escalabilidad masiva.
                </p>
            </div>
        </section>

        <section id="proyectos">
            <h2>Experiencia de Alto Impacto</h2>
            <div class="project-grid">
                <article class="project-card">
                    <header>
                        <span class="company">SURA AFP CAPITAL</span>
                        <h3>Modelo Robot as a Service (RaaS)</h3>
                    </header>
                    <p>Desarrollo de microservicios transaccionales en <strong>Cloud Run</strong> e integración de <strong>IA (OCR/NLP)</strong> para la gestión automatizada de nóminas críticas.</p>
                    <div class="tags">
                        <span>GCP</span><span>Python</span><span>IA</span>
                    </div>
                </article>

                <article class="project-card">
                    <header>
                        <span class="company">CLARO CHILE S.A.</span>
                        <h3>Modernización e Integración</h3>
                    </header>
                    <p>Liderazgo en la integración de sistemas legacy mediante <strong>APIs REST/SOAP</strong>, mejorando la interoperabilidad y experiencia de usuario.</p>
                    <div class="tags">
                        <span>APIs</span><span>Interoperabilidad</span><span>Liderazgo</span>
                    </div>
                </article>
            </div>
        </section>

        <section id="vdd-strategy">
            <h2>Estrategia VDD (Value Driven Delivery)</h2>
            <div class="vdd-table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Modelo</th>
                            <th>Aplicación</th>
                            <th>Meta</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td><strong>WSJF</strong></td><td>Costo del retraso</td><td>Agilidad Financiera</td></tr>
                        <tr><td><strong>RICE / ICE</strong></td><td>Impacto vs Esfuerzo</td><td>ROI de Automatización</td></tr>
                        <tr><td><strong>MoSCoW</strong></td><td>Clasificación Crítica</td><td>Cumplimiento de Plazos</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section id="certificaciones">
            <h2>Certificaciones y Especialización</h2>
            <div class="cert-grid">
                <div class="cert-card gold">
                    <div class="cert-header"><i class="devicon-blueprism-plain colored"></i><span>Oficial</span></div>
                    <h4>Blue Prism Certified Developer</h4>
                    <p>SS&C Blue Prism | 2020</p>
                </div>
                <div class="cert-card tech">
                    <div class="cert-header"><span>Academy 2026</span></div>
                    <h4>Appian Developer</h4>
                    <p>Appian Academy | Low-Code Automation</p>
                </div>
                <div class="cert-card tech">
                    <div class="cert-header"><i class="devicon-uipath-plain colored"></i><span>Academy</span></div>
                    <h4>RPA Developer Foundation</h4>
                    <p>UiPath Academy | EY Consulting</p>
                </div>
                <div class="cert-card">
                    <h4>Análisis de Datos con Python</h4>
                    <p>Desafío Latam | Oct 2025</p>
                    <span class="id">ID: omfqaqs5m0</span>
                </div>
            </div>
        </section>

        <section id="trayectoria">
            <h2>Trayectoria y Formación</h2>
            <div class="timeline">
                <div class="timeline-item"><span class="year">2026</span><h4>Ingeniero de Portafolios TI & RPA</h4><p>Kibernum | SURA AFP Capital.</p></div>
                <div class="timeline-item"><span class="year">2024</span><h4>Posgrado en Gestión de Portafolios</h4><p>Tecnológico de Monterrey | VDD.</p></div>
                <div class="timeline-item"><span class="year">2023 - 2025</span><h4>Líder de Proyectos de Integración</h4><p>Claro Chile.</p></div>
                <div class="timeline-item"><span class="year">2020</span><h4>Ingeniería en Informática</h4><p>IPCHILE.</p></div>
            </div>
        </section>

        <section id="contacto">
            <div class="cta-container">
                <a href="https://linkedin.com/in/cpalaciosborquez" target="_blank" class="btn linkedin">LinkedIn</a>
                <a href="mailto:cpalacios.borquez@gmail.com" class="btn mail">Email</a>
                <a href="/cv_cpalacios.pdf" download class="btn cv">Descargar CV</a>
            </div>
        </section>
    </main>
</Layout>

<style>
    main {
        margin: auto;
        padding: 2rem;
        width: 800px;
        max-width: calc(100% - 2rem);
        color: #ffffff;
        line-height: 1.6;
        font-family: "Inter", sans-serif;
    }
    h1 {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 0;
        background: linear-gradient(45deg, #4f39fa, #da62c4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .role { font-size: 1.5rem; color: #a3a3a3; margin-top: 0.5rem; }
    section { margin-top: 4rem; }
    strong { color: #da62c4; }

    /* Expertise */
    .expertise-grid { display: flex; flex-direction: column; gap: 1rem; }
    .skill-item { display: flex; align-items: center; gap: 1rem; background: #1e1e1e; padding: 1rem; border-radius: 10px; border: 1px solid #333; }
    .skill-item i { font-size: 2rem; }

    /* RaaS */
    .raas-container { background: linear-gradient(135deg, #1e1e1e 0%, #252525 100%); padding: 2rem; border-radius: 16px; border: 1px solid #4f39fa; margin-bottom: 3rem; }
    .raas-badge { background: #4f39fa; color: white; font-size: 0.7rem; padding: 0.3rem 0.8rem; border-radius: 20px; display: inline-block; margin-bottom: 1rem; text-transform: uppercase; font-weight: bold; }

    /* Ticker */
    .tech-ticker { width: 100vw; position: relative; left: 50%; right: 50%; margin-left: -50vw; margin-right: -50vw; overflow: hidden; background: #1e1e1e; padding: 2rem 0; margin-top: 3rem; border-top: 1px solid #333; border-bottom: 1px solid #333; }
    .ticker-content { display: flex; width: max-content; animation: scroll 30s linear infinite; }
    .ticker-content i { font-size: 2.5rem; margin: 0 3rem; color: #666; flex-shrink: 0; }
    @keyframes scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

    /* Cards & Grids */
    .project-grid, .cert-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
    .project-card, .cert-card { padding: 1.5rem; background: #1e1e1e; border: 1px solid #333; border-radius: 12px; transition: 0.2s; }
    .project-card:hover, .cert-card:hover { transform: scale(1.02); border-color: #4f39fa; }
    .company { font-size: 0.8rem; color: #da62c4; font-weight: bold; }
    .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
    .tags span { font-size: 0.7rem; padding: 0.2rem 0.6rem; background: #333; border-radius: 4px; color: #a3a3a3; }

    /* Table */
    table { width: 100%; border-collapse: collapse; margin-top: 1rem; background: #1e1e1e; border-radius: 8px; overflow: hidden; }
    th, td { padding: 12px; text-align: left; border-bottom: 1px solid #333; }
    th { background-color: #252525; color: #da62c4; }

    /* Timeline */
    .timeline { border-left: 2px solid #4f39fa; margin-left: 1rem; padding-left: 2rem; }
    .timeline-item { position: relative; margin-bottom: 2.5rem; }
    .timeline-item::before { content: ""; position: absolute; left: calc(-2rem - 6px); top: 5px; width: 10px; height: 10px; border-radius: 50%; background: #da62c4; }
    .year { font-weight: bold; color: #da62c4; }

    /* Contact */
    .cta-container { display: flex; gap: 1rem; justify-content: center; margin-top: 5rem; padding-bottom: 5rem; }
    .btn { padding: 0.8rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: bold; transition: 0.2s; }
    .linkedin { background: #0077b5; color: white; }
    .mail { background: #4f39fa; color: white; }
    .cv { border: 1px solid #da62c4; color: #da62c4; }

    /* Socials & Badge */
    .social-links { display: flex; gap: 1.5rem; margin-top: 1rem; }
    .social-links a { color: #a3a3a3; font-size: 1.8rem; transition: 0.3s; }
    .social-links a:hover { color: #da62c4; transform: translateY(-3px); }
    .status-badge { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: #4ade80; margin-top: 0.5rem; }
    .dot { width: 8px; height: 8px; background-color: #4ade80; border-radius: 50%; animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
</style>