/* --- LÍNEA DE TIEMPO MODERNA --- */
    .timeline {
        border-left: 2px solid #333; /* Línea principal más sutil */
        margin-left: 1rem;
        padding-left: 2.5rem;
        position: relative;
        margin-top: 2rem;
    }
    
    .timeline-item {
        position: relative;
        margin-bottom: 2.5rem;
    }
    
    /* El "Nodo" o punto en la línea de tiempo */
    .timeline-item::before {
        content: "";
        position: absolute;
        left: calc(-2.5rem - 7px); /* Centrado exacto sobre la línea */
        top: 1.5rem; /* Alineado con la tarjeta */
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #da62c4;
        border: 3px solid #1e1e1e; /* Crea un efecto de anillo */
        box-shadow: 0 0 0 2px #4f39fa; /* Borde exterior morado */
        z-index: 1;
        transition: background 0.3s ease, box-shadow 0.3s ease;
    }

    /* La Tarjeta de Contenido */
    .timeline-content {
        background: #1e1e1e;
        border: 1px solid #333;
        border-radius: 12px;
        padding: 1.5rem;
        transition: transform 0.3s ease, border-color 0.3s ease;
        position: relative;
    }

    /* Efecto Hover: La tarjeta avanza y el nodo brilla */
    .timeline-item:hover .timeline-content {
        border-color: #4f39fa;
        transform: translateX(8px); /* Se mueve un poco a la derecha */
    }
    .timeline-item:hover::before {
        background: #fff;
        box-shadow: 0 0 12px #da62c4, 0 0 0 2px #da62c4;
    }

    /* Tipografía interna de la línea de tiempo */
    .timeline-content .year {
        display: inline-block;
        background: rgba(79, 57, 250, 0.15);
        color: #4ade80; /* Un verde que resalta disponibilidad/actividad */
